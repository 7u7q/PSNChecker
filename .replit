modules = ["dotnet-7.0"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PSNChecker"

[[workflows.workflow]]
name = "PSNChecker"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "dotnet run --project PSNChecker -c Release"

[deployment]
deploymentTarget = "vm"
run = ["dotnet", "publish/PSNChecker.dll"]
build = ["dotnet", "publish", "PSNChecker", "-c", "Release", "-o", "publish"]
